# Copy to .env and fill in. Used by deploy scripts and local tooling.
GCP_PROJECT_ID=visionlog-prod
GCP_REGION=us-central1

# Upload service
GCS_BUCKET_NAME=visionlog-images-visionlog-prod
FIRESTORE_COLLECTION=predictions
API_KEY_SECRET_NAME=visionlog-api-key
LOG_LEVEL=INFO

# Inference worker
VERTEX_ENDPOINT_ID=
MODEL_VERSION=mobilenetv2-v1

# Local development
ENVIRONMENT=local
LOCAL_API_KEY=dev-key-12345
LOCAL_UPLOAD_DIR=/tmp/uploads
FIRESTORE_EMULATOR_HOST=localhost:8081

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8080
VITE_API_KEY=dev-key-12345
